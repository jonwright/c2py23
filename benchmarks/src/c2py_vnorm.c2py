{
  "module": "c2py_vnorm",
  "source": ["tiny_kernel.c"],
  "headers": ["tiny_kernel.h"],
  "timing": true,
  "functions": [
    {
      "py_sig": "vnorm(vec: buffer, mods: buffer) -> void",
      "checks": [
        "vec.format == 'd'",
        "mods.format == 'd'",
        "vec.ndim == 2",
        "mods.ndim == 1",
        "vec.shape[1] == 3",
        "mods.n == vec.shape[0]"
      ],
      "c_overloads": [
        {
          "sig": "vnorm(const double vec[][3], double mods[], ptrdiff_t n)",
          "map": {
            "vec": "vec.ptr",
            "mods": "mods.ptr",
            "n": "vec.shape[0]"
          }
        }
      ]
    }
  ]
}
