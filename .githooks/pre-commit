#!/usr/bin/env bash
# Pre-commit hook: format with black, check 7-bit ASCII, then regenerate
# transform wrapper when source files change.
#
# Files that trigger a wrapper rebuild:
#   c2py23/parser.py  c2py23/generator.py  c2py23/runtime/*.h  c2py23/runtime/*.c
#   tests/cases/transform/transform.c2py  tests/cases/transform/transform.c
set -e

# ============================================================
# 7-bit ASCII check -- all staged text files must be ASCII
# ============================================================
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED" ]; then
    echo "$STAGED" | python3 tools/check_ascii.py || exit 1
fi

# ============================================================
# Black formatting
# ============================================================
STAGED_PY=$(echo "$STAGED" | grep '\.py$' || true)
if [ -n "$STAGED_PY" ]; then
    echo "$STAGED_PY" | xargs python3 -m black --config pyproject.toml 2>/dev/null || true
    echo "$STAGED_PY" | xargs git add
    echo "[pre-commit] Formatted staged .py files with black."
fi

# ============================================================
# Transform wrapper regeneration
# ============================================================
WRAPPER="tests/cases/transform/xfrm_wrapper.c"
TRIGGERS=(
    c2py23/parser.py
    c2py23/generator.py
    c2py23/runtime/c2py_runtime.h
    c2py23/runtime/c2py_runtime.c
    tests/cases/transform/transform.c2py
    tests/cases/transform/transform.c
)

REBUILD=0
for f in "${TRIGGERS[@]}"; do
    if git diff --cached --name-only | grep -q "^$f$"; then
        REBUILD=1
        break
    fi
done
if git diff --cached --name-only | grep -q "^$WRAPPER\$"; then
    REBUILD=0
fi

if [ "$REBUILD" -eq 1 ]; then
    echo "[pre-commit] Rebuilding $WRAPPER..."
    python3 -m c2py23 tests/cases/transform/transform.c2py \
        -o "$WRAPPER"
    git add "$WRAPPER"
    echo "[pre-commit] $WRAPPER regenerated and staged."
fi
